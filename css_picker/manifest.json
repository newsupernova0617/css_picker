{
   "action": {
      "default_title": "Open CSS Picker"
   },
   "background": {
      "service_worker": "service-worker.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "\u003Call_urls>" ]
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'"
   },
   "description": "A Chrome extension for highlighting page elements on hover",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "assets/icon-128.png",
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "CSS Element Picker",
   "oauth2": {
      "client_id": "50897249016-u2s4265ncehujgob91dh0rqqupo50bqh.apps.googleusercontent.com",
      "scopes": [ "https://www.googleapis.com/auth/userinfo.profile", "https://www.googleapis.com/auth/userinfo.email" ]
   },
   "permissions": [ "tabs", "sidePanel", "scripting", "downloads", "activeTab", "storage", "identity", "alarms" ],
   "side_panel": {
      "default_path": "sidepanel.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.1",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "lib/html2canvas.min.js", "lib/jszip.min.js", "lib/bootstrap.bundle.min.js", "sidepanel.js", "sidepanel.css", "gdpr-init.js", "console-injector.js" ]
   } ]
}
