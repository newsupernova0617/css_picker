{
  "manifest_version": 3,
  "name": "CSS Element Picker",
  "description": "A Chrome extension for highlighting page elements on hover",
  "version": "1.0",
  "permissions": [
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open CSS Picker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["jquery.min.js", "content.js"]
    }
  ]
}
